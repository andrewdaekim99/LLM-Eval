{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "rootDir": "."
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "packages/*/bin/**/*.mjs",
    "apps/*/**/*.ts",
    "apps/*/**/*.tsx",
    "eslint.config.mjs",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", ".next", "coverage", ".cache"]
}
