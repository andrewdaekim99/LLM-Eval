# Anthropic API key — server-side only, never bundled to the client (see ADR-0010).
ANTHROPIC_API_KEY=sk-ant-...

# Pinned model snapshot for the system-under-test. Aliases (e.g. *-latest) are rejected.
YARDSTICK_MODEL=claude-haiku-4-5

# Pinned model snapshot for the llmJudge scorer.
YARDSTICK_JUDGE_MODEL=claude-sonnet-4-6

# SQLite database path for run history. Created on first run.
DATABASE_URL=./.cache/yardstick.db

# Disk location for the response cache (see ADR-0004).
CACHE_DIR=./.cache/responses

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
